# OSeduc local development configuration.
# Copy this file to .env for local use. Never commit real API keys.

# mock is the safe default and does not require an API key.
OSEDUC_LLM_PROVIDER=mock

# Use openai_compatible only when you intentionally want live LLM calls.
# OSEDUC_LLM_PROVIDER=openai_compatible
# OSEDUC_LLM_BASE_URL=https://api.openai.com/v1
# OSEDUC_LLM_MODEL=your-model-name
# OSEDUC_LLM_API_KEY=replace-with-your-local-api-key
# OSEDUC_LLM_TIMEOUT_SECS=30

# Local development Postgres. This is a disposable dev credential for compose.yaml,
# not a production secret.
OSEDUC_DATABASE_URL=postgres://oseduc:oseduc_dev_password@127.0.0.1:5432/oseduc
OSEDUC_AUTO_MIGRATE=false
OSEDUC_ENABLE_ADMIN_SEED=false
# Required only when OSEDUC_ENABLE_ADMIN_SEED=true.
# OSEDUC_ADMIN_TOKEN=replace-with-local-admin-token
